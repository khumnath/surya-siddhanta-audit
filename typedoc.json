{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src"
  ],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts"
  ],
  "name": "Siddhanta Parity API Documentation",
  "includeVersion": true,
  "plugin": [],
  "readme": "none",
  "hideGenerator": true,
  "cleanOutputDir": true,
  "disableSources": true,
  "customCss": "scripts/docs-theme.css"
}